      "id": "growth_likes_028",
      "description": "Prioritize like count when replying to @trashh_dev (tweet 2034336106469273662)",
      "input": {
        "scenario": {
          "schema_version": "v1",
          "id": "growth_likes_028",
          "description": "Prioritize like count when replying to @trashh_dev (tweet 2034336106469273662)",
          "sut": {
            "type": "agentic_sdk",
