            ],
            "must_not_events": [],
            "ordering_rules": [],
            "diff_assertions": [],
            "output_assertions": [
              {
                "type": "contains",
                "path": "output.text",
                "values": [
                  "likes",
                  "reply",
                  "tweet"
                ],
                "mode": "any"
              },
              {
                "type": "contains",
                "path": "output.text",
                "values": [
                  "trashh_dev",
                  "108",
                  "20"
                ],
                "mode": "any"
              },
              {
                "type": "not_contains",
                "path": "output.text",
                "values": [
                  "follow train",
                  "follow back",
                  "follow me",
                  "FF ",
                  "follow4follow",
